generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  MANAGER
  STAKEHOLDER
  VENDOR
}

enum ProjectRole {
  PROJECT_MANAGER
  MANAGER
  STAKEHOLDER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

model Organization {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  projects  Project[]
  vendors   Vendor[]
  contracts Contract[]
}

model User {
  id             Int       @id @default(autoincrement())
  fullName       String
  email          String    @unique
  passwordHash   String
  role           Role
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdProjects Project[]    @relation("ProjectCreatedBy")
  projectUsers   ProjectUser[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
}

model Project {
  id             Int          @id @default(autoincrement())
  name           String
  description    String?
  location       String?
  startDate      DateTime?
  endDate        DateTime?
  budget         Decimal?     @db.Decimal(12, 2)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    Int?
  createdBy      User?        @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  projectUsers   ProjectUser[]
  governance     ProjectGovernance?
  contracts      Contract[]
  projectVendors ProjectVendor[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([createdById])
}

model ProjectGovernance {
  projectId                 Int      @id
  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requireContractApproval   Boolean  @default(false)
  requirePaymentApproval    Boolean  @default(false)
  requireTxApproval         Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model Vendor {
  id             Int          @id @default(autoincrement())
  name           String
  email          String?
  phone          String?
  isGlobal       Boolean      @default(false)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts      Contract[]
  projectVendors ProjectVendor[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model ProjectVendor {
  id        Int      @id @default(autoincrement())
  projectId Int
  vendorId  Int
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([projectId, vendorId])
  @@index([projectId])
  @@index([vendorId])
}

model Contract {
  id             Int            @id @default(autoincrement())
  title          String
  description    String?
  totalAmount    Decimal        @db.Decimal(12, 2)
  status         ContractStatus @default(DRAFT)
  organizationId Int
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      Int
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId       Int
  vendor         Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([vendorId])
}

model ProjectUser {
  id          Int         @id @default(autoincrement())
  projectId   Int
  userId      Int
  projectRole ProjectRole
  assignedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}
