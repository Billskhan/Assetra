generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  MANAGER
  STAKEHOLDER
  VENDOR
}

enum ProjectRole {
  PROJECT_MANAGER
  MANAGER
  STAKEHOLDER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TransactionStatus {
  PENDING_PM_APPROVAL
  APPROVED
  REJECTED
  PAID
}

model Organization {
  id                 Int                @id @default(autoincrement())
  name               String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  projects           Project[]
  vendors            Vendor[]
  contracts          Contract[]
  transactions       Transaction[]
  projectUsers       ProjectUser[]
  projectVendors     ProjectVendor[]
  projectGovernances ProjectGovernance[]
  stages             Stage[]
  tasks              Task[]
}

model User {
  id                   Int           @id @default(autoincrement())
  organizationId       Int
  email                String        @unique
  passwordHash         String
  role                 Role
  name                 String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectUsers         ProjectUser[]
  createdProjects      Project[]     @relation("ProjectCreatedBy")
  createdTransactions  Transaction[] @relation("TransactionCreatedBy")

  @@index([organizationId])
}

model Project {
  id             Int           @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  budget         Decimal?      @db.Decimal(12, 2)
  createdById    Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User          @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  projectUsers   ProjectUser[]
  projectVendors ProjectVendor[]
  contracts      Contract[]
  transactions   Transaction[]
  governance     ProjectGovernance?
  stages         Stage[]

  @@index([organizationId])
  @@index([createdById])
}

model ProjectUser {
  id             Int         @id @default(autoincrement())
  organizationId Int
  projectId      Int
  userId         Int
  role           ProjectRole
  createdAt      DateTime    @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
}

model Vendor {
  id             Int         @id @default(autoincrement())
  organizationId Int
  name           String
  email          String?
  phone          String?
  isGlobal       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectVendors ProjectVendor[]
  contracts      Contract[]

  @@index([organizationId])
}

model ProjectVendor {
  id             Int         @id @default(autoincrement())
  organizationId Int
  projectId      Int
  vendorId       Int
  createdAt      DateTime    @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor         Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([projectId, vendorId])
  @@index([organizationId])
  @@index([projectId])
  @@index([vendorId])
}

model Contract {
  id             Int            @id @default(autoincrement())
  organizationId Int
  projectId      Int
  vendorId       Int
  title          String
  description    String?
  totalAmount    Decimal        @db.Decimal(12, 2)
  status         ContractStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor         Vendor         @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  transactions   Transaction[]

  @@index([organizationId])
  @@index([projectId])
  @@index([vendorId])
}

model Transaction {
  id             Int               @id @default(autoincrement())
  organizationId Int
  projectId      Int
  contractId     Int?
  title          String
  status         TransactionStatus @default(PENDING_PM_APPROVAL)
  totalAmount    Decimal           @db.Decimal(12, 2)
  createdById    Int
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contract       Contract?         @relation(fields: [contractId], references: [id], onDelete: SetNull)
  createdBy      User              @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items          TransactionItem[]

  @@index([organizationId])
  @@index([projectId])
  @@index([contractId])
  @@index([createdById])
  @@index([status])
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId Int
  name          String
  quantity      Int
  unitPrice     Decimal     @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model ProjectGovernance {
  id               Int          @id @default(autoincrement())
  organizationId   Int
  projectId        Int          @unique
  approvalRequired Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Stage {
  id             Int         @id @default(autoincrement())
  organizationId Int
  projectId      Int
  name           String
  order          Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@index([organizationId])
  @@index([projectId])
}

model Task {
  id             Int         @id @default(autoincrement())
  organizationId Int
  stageId        Int
  name           String
  description    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage          Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stageId])
}
